---
import Base from '../../layouts/Base.astro';
import NewsGrid from '../../components/NewsGrid.astro';
import { fetchAllNews, filterByCategory } from '../../data/news-bridge';
import ja from '../../i18n/ja.json';

const i = ja;
const news = await fetchAllNews();
const items = filterByCategory(news, 'education');
---
<Base lang="ja" title={i.nav.education} description={`${i.nav.education} — ${i.site.tagline}`}>
  <h1>{i.nav.education}</h1>
  <p style="color: var(--text-muted); margin-bottom: 24px;">
    Sources: Inside Higher Ed / The Hechinger Report
  </p>
  {items.length > 0 ? (
    <NewsGrid items={items} lang="ja" />
  ) : (
    <p>{i.home.no_news}</p>
  )}
</Base>
