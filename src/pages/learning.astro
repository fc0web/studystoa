---
import Base from '../layouts/Base.astro';
import NewsGrid from '../components/NewsGrid.astro';
import { fetchAllNews, filterByCategory } from '../data/news-bridge';
import en from '../i18n/en.json';

const i = en;
const news = await fetchAllNews();
const items = filterByCategory(news, 'learning');
---
<Base lang="en" title={i.nav.learning} description={`${i.nav.learning} — ${i.site.tagline}`}>
  <h1>{i.nav.learning}</h1>
  <p style="color: var(--text-muted); margin-bottom: 24px;">
    Sources: Hacker News education stories (via Algolia API).
  </p>
  {items.length > 0 ? (
    <NewsGrid items={items} lang="en" />
  ) : (
    <p>{i.home.no_news}</p>
  )}
</Base>
