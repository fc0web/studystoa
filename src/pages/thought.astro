---
import Base from '../layouts/Base.astro';
import NewsGrid from '../components/NewsGrid.astro';
import { fetchAllNews, filterByCategory } from '../data/news-bridge';
import en from '../i18n/en.json';

const i = en;
const news = await fetchAllNews();
const items = filterByCategory(news, 'thought');
---
<Base lang="en" title={i.nav.thought} description={`${i.nav.thought} — ${i.site.tagline}`}>
  <h1>{i.nav.thought}</h1>
  <p style="color: var(--text-muted); margin-bottom: 24px;">
    Sources: Crooked Timber, 3 Quarks Daily, The Conversation (CC-BY-ND-4.0).
  </p>
  {items.length > 0 ? (
    <NewsGrid items={items} lang="en" />
  ) : (
    <p>{i.home.no_news}</p>
  )}
</Base>
